DATABASE_URL="postgresql://marketplace:marketplace@localhost:5433/marketplace_analytics"
JWT_SECRET="replace-with-at-least-32-random-characters"
ENCRYPTION_KEY="replace-with-32-byte-base64-key"
PORT="4000"
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5173"
EMAIL_CODE_TTL_MINUTES="10"

# Если SMTP не настроен, код входа выводится в лог сервера.
SMTP_HOST="smtp.go2.unisender.ru"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your_unisender_user_or_project_id"
SMTP_PASSWORD="your_unisender_api_key"
SMTP_FROM="Marketplace Analytics <verified-sender@example.com>"
