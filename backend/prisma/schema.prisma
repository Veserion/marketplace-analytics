generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  owner
  admin
  member
}

enum Marketplace {
  ozon
  wildberries
}

enum ConnectionStatus {
  not_connected
  connected
  invalid
}

enum AuditAction {
  email_code_requested
  email_code_verified
  user_registered
  user_logged_in
  credentials_saved
  credentials_deleted
}

enum WbReportStatus {
  processing
  ready
  error
}

enum WbReportType {
  weekly_detailed
}

enum StoredArtifactStatus {
  processing
  ready
  error
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships    OrganizationMember[]
  auditLogs      AuditLog[]
  requestedWbReports WbApiReport[]
  uploadedCogsFiles MarketplaceCogsFile[]
}

model EmailAuthCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrganizationMember[]
  connections MarketplaceConnection[]
  auditLogs   AuditLog[]
  wbReports   WbApiReport[]
  cogsFiles   MarketplaceCogsFile[]
  cogsItems   MarketplaceCogsItem[]
  metricSnapshots MarketplaceWeeklyMetricSnapshot[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(member)
  createdAt      DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model MarketplaceConnection {
  id                   String           @id @default(cuid())
  organizationId       String
  marketplace          Marketplace
  status               ConnectionStatus @default(not_connected)
  encryptedCredentials String?
  credentialPreview    String?
  encryptionKeyVersion Int              @default(1)
  lastCheckedAt        DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, marketplace])
  @@index([organizationId])
}

model MarketplaceRateLimitState {
  id                      String    @id @default(cuid())
  scopeKey                String    @unique
  organizationId          String
  marketplace             Marketplace
  marketplaceConnectionId String?
  blockedUntil            DateTime?
  lastRetryAfterSeconds   Int?
  lastResetSeconds        Int?
  lastLimit               Int?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([organizationId, marketplace])
  @@index([blockedUntil])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String?
  userId         String?
  action         AuditAction
  metadata       Json?
  createdAt      DateTime    @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
}

model WbApiReport {
  id                  String         @id @default(cuid())
  organizationId      String
  marketplace         String         @default("wildberries")
  reportType          WbReportType   @default(weekly_detailed)
  periodFrom          DateTime
  periodTo            DateTime
  status              WbReportStatus @default(processing)
  errorMessage        String?
  rowsCount           Int            @default(0)
  fileName            String?
  filePath            String?
  fileSize            BigInt?
  fileHash            String?
  mimeType            String         @default("application/json")
  requestedFields     Json           @default("[]")
  wbEndpoint          String         @default("/api/wb-finance/sales-reports/detailed")
  requestedByUserId   String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  refreshedAt         DateTime?
  deletedAt           DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy  User?        @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, marketplace, reportType, periodFrom, periodTo], name: "uniq_wb_api_report_week")
  @@index([organizationId, periodFrom, periodTo], name: "idx_wb_api_reports_company_period")
  @@index([organizationId, status], name: "idx_wb_api_reports_company_status")
}

model MarketplaceCogsFile {
  id               String               @id @default(cuid())
  organizationId   String
  marketplace      Marketplace
  fileName         String
  filePath         String
  fileSize         BigInt
  fileHash         String
  mimeType         String               @default("text/csv")
  rowsCount        Int                  @default(0)
  status           StoredArtifactStatus @default(processing)
  errorMessage     String?
  uploadedByUserId String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User?                 @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  cogsItems      MarketplaceCogsItem[]
  metricSnapshots MarketplaceWeeklyMetricSnapshot[]

  @@index([organizationId, marketplace, deletedAt], name: "idx_marketplace_cogs_files_org_marketplace_deleted")
  @@index([organizationId, marketplace, status], name: "idx_marketplace_cogs_files_org_marketplace_status")
}

model MarketplaceCogsItem {
  id                String      @id @default(cuid())
  organizationId    String
  marketplace       Marketplace
  cogsFileId        String
  article           String
  articleNormalized String
  articleDigits     String?
  unitCost          Decimal     @db.Decimal(14, 4)
  currency          String      @default("RUB")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cogsFile     MarketplaceCogsFile @relation(fields: [cogsFileId], references: [id], onDelete: Cascade)

  @@index([organizationId, marketplace, articleNormalized], name: "idx_marketplace_cogs_items_article")
  @@index([organizationId, marketplace, articleDigits], name: "idx_marketplace_cogs_items_article_digits")
  @@index([cogsFileId], name: "idx_marketplace_cogs_items_file")
}

model MarketplaceWeeklyMetricSnapshot {
  id                String               @id @default(cuid())
  organizationId    String
  marketplace       Marketplace
  reportType        String
  periodFrom        DateTime
  periodTo          DateTime
  sourceReportId    String?
  cogsFileId        String?
  cogsHash          String
  calculatorVersion String
  status            StoredArtifactStatus @default(processing)
  atoms             Json                 @default("{}")
  molecules         Json                 @default("{}")
  cells             Json                 @default("{}")
  breakdowns        Json                 @default("{}")
  dataQuality       Json                 @default("{}")
  rowsCount         Int                  @default(0)
  errorMessage      String?
  calculatedAt      DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cogsFile     MarketplaceCogsFile?  @relation(fields: [cogsFileId], references: [id], onDelete: SetNull)

  @@unique([organizationId, marketplace, reportType, periodFrom, periodTo, cogsHash, calculatorVersion], name: "uniq_marketplace_weekly_metric_snapshot")
  @@index([organizationId, marketplace, periodFrom, periodTo], name: "idx_marketplace_weekly_metric_snapshots_period")
  @@index([organizationId, marketplace, status], name: "idx_marketplace_weekly_metric_snapshots_status")
}
